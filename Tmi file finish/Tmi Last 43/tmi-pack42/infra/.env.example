# TMI PLATFORM — COMPLETE ENV VARIABLES
# Copy to .env.local and fill in values.
# Never commit .env.local to git.

# ── DATABASE ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tmi?schema=public"
DATABASE_POOL_SIZE=10

# ── AUTH ─────────────────────────────────────────────────
JWT_SECRET="change-me-to-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
NEXTAUTH_SECRET="change-me-to-random-32-char-string"
NEXTAUTH_URL="http://localhost:3001"

# ── GOOGLE OAUTH ─────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── APPLE OAUTH ──────────────────────────────────────────
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# ── REDIS (cache + queue + sessions) ────────────────────
REDIS_URL="redis://:redispassword@localhost:6379"
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=3600
REDIS_QUEUE_PREFIX="tmi"

# ── SEARCH (Meilisearch) ─────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="meili-master-key-change-in-prod"

# ── OBJECT STORAGE (Cloudflare R2 / AWS S3) ─────────────
STORAGE_PROVIDER="r2"          # r2 | s3 | minio
STORAGE_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"
STORAGE_BUCKET="tmi-media"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_PUBLIC_URL="https://media.themusiciansindex.com"
# For local dev with MinIO:
# STORAGE_ENDPOINT="http://localhost:9000"
# STORAGE_ACCESS_KEY="minioadmin"
# STORAGE_SECRET_KEY="minioadmin123"

# ── CDN ──────────────────────────────────────────────────
CDN_BASE_URL="https://media.themusiciansindex.com"
CDN_CACHE_IMAGES_SECONDS=31536000   # 1 year
CDN_CACHE_AUDIO_SECONDS=3600        # 1 hour
CDN_CACHE_VIDEO_HLS_SEGMENTS=0      # never cache HLS segments

# ── EMAIL (Resend — recommended) ─────────────────────────
EMAIL_PROVIDER="resend"             # resend | sendgrid | ses
RESEND_API_KEY=""
EMAIL_FROM="The Musician's Index <noreply@themusiciansindex.com>"
EMAIL_REPLY_TO="support@themusiciansindex.com"
# For local dev (MailHog):
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="localhost"
# SMTP_PORT=1025

# ── PUSH NOTIFICATIONS ───────────────────────────────────
FCM_PROJECT_ID=""                   # Firebase Cloud Messaging
FCM_PRIVATE_KEY=""
FCM_CLIENT_EMAIL=""
VAPID_PUBLIC_KEY=""                 # Web Push
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:push@themusiciansindex.com"

# ── PAYMENTS (Stripe) ────────────────────────────────────
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CONNECT_CLIENT_ID=""        # for artist payouts
PLATFORM_FEE_PERCENT=10            # 10% platform fee on sales

# ── MEDIA PROCESSING ────────────────────────────────────
FFMPEG_PATH="/usr/bin/ffmpeg"
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=10800   # 3 hours
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/gif"
ALLOWED_VIDEO_TYPES="video/mp4,video/webm,video/mov,video/avi"
ALLOWED_AUDIO_TYPES="audio/mpeg,audio/wav,audio/ogg,audio/aac"

# ── LIVESTREAM (Mux — recommended) ──────────────────────
STREAM_PROVIDER="mux"              # mux | cloudflare | agora
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""

# ── CONTENT MODERATION (AI) ─────────────────────────────
MODERATION_PROVIDER="openai"       # openai | hive | sightengine
OPENAI_API_KEY=""
MODERATION_AUTO_APPROVE=false

# ── ANALYTICS ───────────────────────────────────────────
ANALYTICS_PROVIDER="posthog"       # posthog | segment | mixpanel
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ── ERROR TRACKING (Sentry) ──────────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"   # development | staging | production

# ── WEBSOCKET ────────────────────────────────────────────
WS_PORT=4001
WS_CORS_ORIGIN="http://localhost:3001"

# ── API ──────────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000
API_RATE_LIMIT_WINDOW_MS=60000     # 1 minute
API_RATE_LIMIT_MAX=100             # 100 requests per minute

# ── WEB ──────────────────────────────────────────────────
WEB_URL="http://localhost:3001"
WEB_PORT=3001

# ── BOTS ─────────────────────────────────────────────────
BOTS_ENABLED=false                 # false in dev, true in prod
BOT_BILLING_INTEGRITY_INTERVAL_HOURS=4   # Platform Law #2
BOT_HOUSE_AD_FALLBACK_ENABLED=true       # Platform Law #7

# ── PLATFORM OWNER (Big Ace) ────────────────────────────
BIG_ACE_EMAIL="berntmusic33@gmail.com"
BIG_ACE_PAYPAL=""
JAY_PAUL_PAYPAL=""
WEEKLY_PROFIT_REPORT_EMAIL="berntmusic33@gmail.com"

# ── FEATURE FLAGS (defaults) ─────────────────────────────
FEATURE_VR_ENABLED=false
FEATURE_STADIUM_ENABLED=false
FEATURE_FACE_SCAN_ENABLED=false
FEATURE_AI_BROADCASTER_ENABLED=false
FEATURE_STORE_ENABLED=false
FEATURE_CREATOR_STORE_ENABLED=false
FEATURE_NFT_ENABLED=false
FEATURE_SMS_ENABLED=false
