// PACK 43: REWARDS / GIVEAWAYS / AVATAR ECONOMY — SCHEMA ADDITIONS
// Append to packages/db/prisma/schema.prisma
// Run: pnpm prisma migrate dev --name pack43_rewards

// ── NEW ENUMS ──────────────────────────────────────────────

enum RewardType {
  POINTS AVATAR_ITEM SPONSOR_ITEM DISCOUNT_CODE FREE_TICKET
  BACKSTAGE_PASS MERCH_ITEM DIGITAL_COLLECTIBLE BADGE TITLE
  RANK_BOOST SHOUTOUT SKIP_QUEUE PRIORITY_ENTRY BONUS_VOTE
  MYSTERY_BOX WALLET_CREDIT
}

enum RewardTrigger {
  RANDOM_AUDIENCE_DROP RANDOM_CONTESTANT_DROP FIRST_TO_REACT
  FIRST_CORRECT_ANSWER FIRST_TO_JOIN_ROOM FIRST_TICKET_BUYER
  FASTEST_RESPONSE MODERATOR_MANUAL_GIFT HOST_MANUAL_GIFT
  SPONSOR_TRIGGERED BOT_TRIGGERED STREAK_REWARD ATTENDANCE_REWARD
  PARTICIPATION_REWARD LOYALTY_REWARD SURPRISE_LIVE_DROP
  MILESTONE_REWARD LEADERBOARD_REWARD CONTEST_WINNER
  AUDIENCE_VOTE_WINNER CHALLENGE_COMPLETION REFERRAL_REWARD
}

enum FulfillmentStatus {
  PENDING PROCESSING FULFILLED FAILED FRAUD_REVIEW REQUIRES_BIG_ACE EXPIRED
}

enum PromptType {
  TRIVIA REACTION FASTEST_TAP FILL_BLANK PICK_WINNER SHOUTOUT_REQUEST
}

// ── MODELS ────────────────────────────────────────────────

model RewardRule {
  id                         String        @id @default(cuid())
  name                       String
  rewardType                 RewardType
  triggerType                RewardTrigger
  pointsAmount               Int?          // for POINTS reward
  itemId                     String?       // for item rewards
  discountPct                Int?          // for DISCOUNT_CODE
  walletCreditCents          Int?          // Big Ace required if > 0
  eligibleRoles              String[]
  eligibleRoomTypes          String[]
  minimumWatchTimeSeconds    Int           @default(0)
  minimumParticipationActions Int          @default(0)
  requiresTicket             Boolean       @default(false)
  requiresVerifiedAccount    Boolean       @default(false)
  dropOddsPct                Float         @default(100)
  maxClaimsPerUser           Int           @default(1)
  maxClaimsPerEvent          Int           @default(0)  // 0 = unlimited
  maxClaimsPerSession        Int           @default(0)
  cooldownSeconds            Int           @default(0)
  minAccountAgeDays          Int           @default(0)
  maxVelocityPerMinute       Int           @default(10)
  requiresRoomPresence       Boolean       @default(true)
  requiresBigAceApproval     Boolean       @default(false)
  sponsorId                  String?
  campaignId                 String?
  availableFrom              DateTime?
  availableUntil             DateTime?
  isActive                   Boolean       @default(true)
  createdAt                  DateTime      @default(now())

  claims                     RewardClaim[]
  prompts                    AudiencePrompt[]

  @@index([isActive])
  @@index([triggerType])
  @@map("reward_rules")
}

model RewardClaim {
  id                  String             @id @default(cuid())
  userId              String
  ruleId              String
  sessionId           String?            // room or game session
  eventId             String?
  roomId              String?
  rewardType          RewardType
  status              FulfillmentStatus  @default(PENDING)
  pointsGranted       Int?
  itemGrantedId       String?
  discountCode        String?
  walletCreditCents   Int?
  requiresBigAce      Boolean            @default(false)
  requiresFraudReview Boolean            @default(false)
  fraudReviewNote     String?
  fulfilledAt         DateTime?
  expiredAt           DateTime?
  claimedAt           DateTime           @default(now())

  rule                RewardRule         @relation(fields: [ruleId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([claimedAt])
  @@map("reward_claims")
}

model AudiencePrompt {
  id              String      @id @default(cuid())
  sessionId       String
  roomId          String
  ruleId          String
  promptType      PromptType
  question        String?
  correctAnswer   String?
  windowSeconds   Int         @default(15)
  maxWinners      Int         @default(1)
  status          String      @default("pending")
  winners         String[]    // userIds
  firedAt         DateTime?
  closedAt        DateTime?
  createdAt       DateTime    @default(now())

  rule            RewardRule  @relation(fields: [ruleId], references: [id])
  entries         AudiencePromptEntry[]

  @@index([sessionId])
  @@map("audience_prompts")
}

model AudiencePromptEntry {
  id              String         @id @default(cuid())
  promptId        String
  userId          String
  response        String?
  responseTimeMs  Int
  isCorrect       Boolean?
  isWinner        Boolean        @default(false)
  pointsAwarded   Int            @default(0)
  submittedAt     DateTime       @default(now())

  prompt          AudiencePrompt @relation(fields: [promptId], references: [id])

  @@unique([promptId, userId])
  @@map("audience_prompt_entries")
}

model DropTable {
  id                    String           @id @default(cuid())
  name                  String
  sponsorId             String?
  eventId               String?
  guaranteedAfterNDraws Int?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())

  entries               DropTableEntry[]

  @@map("drop_tables")
}

model DropTableEntry {
  id           String    @id @default(cuid())
  tableId      String
  rewardType   RewardType
  itemId       String?
  pointsAmount Int?
  weight       Int       @default(100)
  rarity       ItemRarity @default(COMMON)
  maxTotal     Int?
  droppedCount Int       @default(0)

  table        DropTable @relation(fields: [tableId], references: [id])

  @@map("drop_table_entries")
}

model RewardCooldown {
  id        String   @id @default(cuid())
  userId    String
  ruleId    String
  expiresAt DateTime

  @@unique([userId, ruleId])
  @@map("reward_cooldowns")
}

model RewardFraudFlag {
  id          String   @id @default(cuid())
  userId      String
  claimId     String   @unique
  reason      String
  patternData Json?
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isResolved])
  @@map("reward_fraud_flags")
}

model SponsorPrizeCatalog {
  id          String    @id @default(cuid())
  sponsorId   String
  name        String
  description String?
  imageUrl    String?
  totalQty    Int
  remaining   Int
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([sponsorId])
  @@map("sponsor_prize_catalog")
}
