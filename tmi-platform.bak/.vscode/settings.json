{
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/.ci-repro-build/**": true,
    "**/temp_cleanup/**": true,
    "**/docs/**": true,
    "**/.pnpm/**": true,
    "**/coverage/**": true,
    "**/.cache/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/.ci-repro-build": true,
    "**/temp_cleanup": true,
    "**/docs": true,
    "**/.pnpm": true,
    "**/coverage": true,
    "**/.cache": true
  },
  "typescript.tsserver.maxTsServerMemory": 4096,
  "eslint.workingDirectories": [
    { "directory": "apps/web", "changeProcessCWD": true },
    { "directory": "apps/api", "changeProcessCWD": true }
  ],
  "cSpell.words": [
    "Bernout",
    "Berntout",
    "TMI",
    "SACCALUWA",
    "Chari",
    "Blackbox",
    "Copilot",
    "Julius",
    "Cypher",
    "Beatlab",
    "HUD",
    "pnpm",
    "turbo",
    "nextauth",
    "prisma",
    "NestJS",
    "monorepo",
    "tsconfig",
    "eslintrc",
    "eslintignore",
    "noEmit",
    "skipLibCheck",
    "forceConsistentCasingInFileNames",
    "moduleResolution",
    "emitDecoratorMetadata",
    "experimentalDecorators",
    "outDir",
    "baseUrl",
    "resolveJsonModule",
    "isolatedModules",
    "incremental",
    "ignoreDeprecations"
  ]
}
