# TMI Platform API - Environment Variables
# Copy this file to .env and fill in the values

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── OPTIONAL (defaults shown) ─────────────────────────────────────────────────
# Server port (default: 4000)
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# Allowed CORS origins (comma-separated, or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis connection URL (for BullMQ workers — optional, workers disabled if not set)
REDIS_URL=redis://localhost:6379

# JWT secret for token signing (optional — session-based auth used by default)
JWT_SECRET=change-me-in-production

# Session secret (optional)
SESSION_SECRET=change-me-in-production

# Allowed origin for CSRF origin/referer validation (optional)
ALLOWED_ORIGIN=http://localhost:3000

# Cookie domain (optional — leave blank for localhost)
COOKIE_DOMAIN=

# Meilisearch (optional — search falls back to Prisma if not set)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# Mux (optional — media streaming)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Cloudflare R2 / Images (optional — media uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Build identity (optional — set by CI)
BUILD_COMMIT_SHA=
BUILD_RELEASE_TAG=
BUILD_APP_VERSION=

# Auth debug (NEVER enable in production)
AUTH_DEBUG_ENABLED=false

# Readyz optional upstream health checks (comma-separated URLs)
READYZ_OPTIONAL_UPSTREAMS=
