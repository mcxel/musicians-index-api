# Shared defaults (web/api can read from root or their own .env)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# BerntoutGlobal XXL Environment Variables
# Copy this file to .env and fill in the values.

# -----------------
# DATABASE
# -----------------
# The connection string for your PostgreSQL database.
# Prisma uses this to connect to the database.
# Example: "postgresql://user:password@localhost:5432/mydatabase"
DATABASE_URL="postgresql://docker:docker@localhost:5432/berntoutglobal"

# -----------------
# NEXT-AUTH
# -----------------
# A secret used to sign and encrypt tokens, cookies, and sessions.
# You can generate a good secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-key"

# The canonical URL of your production site.
# This is used for redirects and security.
NEXTAUTH_URL="http://localhost:3000"

# -----------------
# STRIPE
# -----------------
# Your Stripe secret key. Keep this private.
STRIPE_SECRET_KEY="sk_test_..."

# Your Stripe publishable key. This is safe to expose to the client.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# The secret for verifying Stripe webhook signatures.
STRIPE_WEBHOOK_SECRET="whsec_..."
