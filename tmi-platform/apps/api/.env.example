# Required runtime boot env (fail-fast)
DATABASE_URL="postgresql://user:password@localhost:5432/tmi_platform"

# Optional runtime boot env (validated when provided)
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional build identity metadata (operator-visible in /api/healthz and /api/readyz)
BUILD_COMMIT_SHA=
BUILD_RELEASE_TAG=
BUILD_APP_VERSION=

# Optional promotion metrics gate env (apps/api/scripts/readyz-rollout-gate.ts)
PROMOTION_METRICS_REQUIRED=false
PROMOTION_METRICS_URL=
PROMOTION_METRICS_FILE=
PROMOTION_METRICS_JSON=
PROMOTION_METRICS_CONTRACT_NAME=tmi-platform-promotion-metrics
PROMOTION_METRICS_CONTRACT_VERSION=1.0

# Optional canonical pipeline rollback env (scripts/pipeline-promotion-gate.js)
PIPELINE_ROLLBACK_CMD=
PIPELINE_ROLLBACK_RESULT=

# Optional readiness/cache env
REDIS_URL=
READYZ_OPTIONAL_UPSTREAMS=
READYZ_OPTIONAL_UPSTREAM_TIMEOUT_OVERRIDES=

# Optional readiness alert env
READYZ_ALERT_THRESHOLD=3
READYZ_ALERT_COOLDOWN_MS=300000
READYZ_ALERT_WEBHOOK_URL=
