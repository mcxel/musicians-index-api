# Danika's Law — Environment Variables
# Copy to .env.local and fill in real values before running

# ── Auth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://law.berntout.com

# ── Database ─────────────────────────────────────────────────────────────
# Each module owns its own DB — do NOT share with apps/web
DATABASE_URL=postgresql://user:password@localhost:5432/berntout_law

# ── Payments ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Redis ────────────────────────────────────────────────────────────────
# Namespace prefix: law: — never collides with other modules
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=law

# ── Module Identity ───────────────────────────────────────────────────────
NEXT_PUBLIC_MODULE_ID=law
NEXT_PUBLIC_MODULE_NAME=Danika's Law
PORT=3001

# ── Stimulation ───────────────────────────────────────────────────────────
STIMULATION_ENABLED=false
STIMULATION_MODE=QUIET
STIMULATION_INTENSITY=0.3

# ── Referral (inbound from TMI) ───────────────────────────────────────────
TMI_REFERRAL_SECRET=
TMI_ORIGIN=https://themusiciansindex.com
