# BerntoutGlobal XXL - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here
ROUTING_STATE_SECRET=your-routing-state-secret-key-here

# =============================================================================
# API CONFIGURATION  
# =============================================================================
# Server-side proxy target — set to your deployed API URL in production
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
RUNTIME_STATUS_BASE_URL=http://localhost:8000

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/berntout

# =============================================================================
# AUTH PROVIDERS — Google OAuth (required for "Continue with Google")
# =============================================================================
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth Client ID → Web Application
# 3. Add Authorized redirect URIs:
#      https://themusiciansindex.com/api/auth/google/callback
#      http://localhost:3000/api/auth/google/callback   (local dev)
# 4. Paste the values below and add to Vercel → Environment Variables
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# STRIPE PAYMENTS (Test Mode)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# EMAIL — Resend (primary transactional provider)
# =============================================================================
# Get your API key at https://resend.com/api-keys
# Domain must be verified for themusiciansindex.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=support@themusiciansindex.com
# Optional fallback (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM_ADDRESS=noreply@themusiciansindex.com
EMAIL_FROM_NAME=TMI Platform

# =============================================================================
# EMAIL QUEUE CRON (Vercel)
# =============================================================================
# Set CRON_SECRET in Vercel dashboard → Project Settings → Environment Variables
# Vercel injects this as Authorization: Bearer <CRON_SECRET> on cron requests
CRON_SECRET=your-cron-secret-here
# Optional manual flush key (for local testing)
QUEUE_FLUSH_KEY=tmi-queue-flush-dev

# =============================================================================
# FILE UPLOADS — Vercel Blob
# =============================================================================
# Required for audio/video uploads from artist/performer playlists
# Get it from Vercel dashboard → Storage → Blob → your store → .env.local button
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# =============================================================================
# AI / CLAUDE (Voice Director + MCP Command Processing)
# =============================================================================
# Get your API key at https://console.anthropic.com/
# Used by /api/voice/command to process spoken platform commands
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# GOOGLE ADSENSE — Ad Slot IDs
# =============================================================================
# Publisher ID is already hardcoded: ca-pub-4088577529436039
# To activate individual slots:
#   1. Go to Google AdSense → Ads → By ad unit → New display ad unit
#   2. Create one ad unit per placement (name them to match below)
#   3. Copy the "data-ad-slot" value (a numeric ID like 1234567890)
#   4. Paste it below and add to Vercel → Environment Variables
#
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_LIVE_LOBBY_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_SPONSOR_FALLBACK=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Set to 'true' to enable features (optional)
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_BATTLES=false
# NEXT_PUBLIC_ENABLE_STREAMWIN=false
