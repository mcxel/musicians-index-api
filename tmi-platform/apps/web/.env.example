# BerntoutGlobal XXL — TMI Platform Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# =============================================================================
# APP / PLATFORM
# =============================================================================
NEXT_PUBLIC_APP_URL=https://themusiciansindex.com
NEXT_PUBLIC_BASE_URL=https://themusiciansindex.com
NEXT_PUBLIC_SITE_URL=https://themusiciansindex.com
NEXT_PUBLIC_URL=https://themusiciansindex.com
NEXT_PUBLIC_API_URL=https://themusiciansindex.com/api
NEXT_PUBLIC_WS_URL=wss://themusiciansindex.com
NEXT_PUBLIC_TICKETS_API_BASE=https://themusiciansindex.com/api/tickets
NEXT_PUBLIC_TMI_FEED_SOCKET_URL=wss://themusiciansindex.com/live
NEXT_PUBLIC_ENVIRONMENT=production
# Set to 'true' while in beta
NEXT_PUBLIC_BETA_END_TIME=
# ISO date string for beta end time
API_BASE_URL=http://localhost:4000
RUNTIME_STATUS_BASE_URL=http://localhost:8000
RUNTIME_STATUS_SECRET=your-runtime-status-secret
WEB_ORIGIN=https://themusiciansindex.com

# =============================================================================
# DATABASE
# =============================================================================
# CONNECTION POOLER URL — used by the app at runtime (pgBouncer / Neon pooler)
# Neon:      postgres://user:password@ep-xxx.pooler.neon.tech/neondb?sslmode=require
# Supabase:  postgres://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true
# Railway:   postgresql://postgres:[password]@[host]:5432/railway
DATABASE_URL=postgresql://user:password@localhost:5432/tmi

# DIRECT (non-pooled) URL — used by prisma migrate only (not runtime)
DIRECT_URL=postgresql://user:password@localhost:5432/tmi

# =============================================================================
# AUTH (NextAuth / JWT)
# =============================================================================
NEXTAUTH_URL=https://themusiciansindex.com
NEXTAUTH_SECRET=your-nextauth-secret-here
JWT_SECRET=your-jwt-secret-here
REFRESH_SECRET=your-refresh-secret-here
ROUTING_STATE_SECRET=your-routing-state-secret-here

# =============================================================================
# AUTH PROVIDERS — Google OAuth
# =============================================================================
# Console: https://console.cloud.google.com/apis/credentials
# Add redirect URIs: https://themusiciansindex.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# Used by next-auth v5 provider style
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-your-google-client-secret
# Legacy alias
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-google-client-secret

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Clerk (optional — if using Clerk auth layer)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Set to 'true' to pause Stripe (maintenance mode)
STRIPE_PAUSE_MODE=false
# Only accept webhook events from localhost during dev
STRIPE_WEBHOOK_LOCAL_ONLY=false

# --- Stripe Price IDs (Performer tiers) ---
STRIPE_PRICE_PERFORMER_SILVER=price_...
STRIPE_PRICE_PERFORMER_GOLD=price_...
STRIPE_PRICE_PERFORMER_RUBY=price_...
STRIPE_PRICE_PERFORMER_PLATINUM=price_...
STRIPE_PRICE_PERFORMER_DIAMOND=price_...
STRIPE_PRICE_PERFORMER_BAND=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_SILVER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_GOLD=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_RUBY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_PLATINUM=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_DIAMOND=price_...
NEXT_PUBLIC_STRIPE_PRICE_PERFORMER_BAND=price_...

# --- Stripe Price IDs (Fan tiers) ---
STRIPE_PRICE_FAN_SILVER=price_...
STRIPE_PRICE_FAN_GOLD=price_...
STRIPE_PRICE_FAN_RUBY=price_...
STRIPE_PRICE_FAN_PLATINUM=price_...
STRIPE_PRICE_FAN_DIAMOND=price_...
STRIPE_PRICE_FAN_FAMILY=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_SILVER=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_GOLD=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_RUBY=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_PLATINUM=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_DIAMOND=price_...
NEXT_PUBLIC_STRIPE_PRICE_FAN_FAMILY=price_...

# --- Stripe Price IDs (Advertising) ---
STRIPE_PRICE_AD_BANNER=price_...
STRIPE_PRICE_AD_BILLBOARD=price_...
STRIPE_PRICE_AD_MAGAZINE=price_...
STRIPE_PRICE_AD_TICKER=price_...
STRIPE_PRICE_AD_VIDEO=price_...

# --- Stripe Price IDs (Sponsorship) ---
STRIPE_PRICE_SPONSOR_ARTICLE=price_...
STRIPE_PRICE_SPONSOR_BANNER=price_...
STRIPE_PRICE_SPONSOR_BATTLE=price_...
STRIPE_PRICE_SPONSOR_CHAMPIONSHIP=price_...
STRIPE_PRICE_SPONSOR_CONTEST=price_...
STRIPE_PRICE_SPONSOR_ROOM=price_...

# --- Stripe Price IDs (Beats / Content) ---
STRIPE_PRICE_BEAT_BASIC=price_...
STRIPE_PRICE_BEAT_PREMIUM=price_...
STRIPE_PRICE_BEAT_EXCLUSIVE=price_...
STRIPE_PRICE_BEAT_FEATURED=price_...
STRIPE_PRICE_BEAT_LICENSE=price_...

# --- Stripe Price IDs (Tickets / Events) ---
STRIPE_PRICE_TICKET_STANDARD=price_...
STRIPE_PRICE_TICKET_VIP=price_...
STRIPE_PRICE_BACKSTAGE_PASS=price_...
STRIPE_PRICE_MEET_GREET=price_...
STRIPE_PRICE_SEAT_FRONT=price_...
STRIPE_PRICE_SEAT_VIP=price_...

# --- Stripe Price IDs (Other) ---
STRIPE_PRICE_BOOKING_FEE=price_...
STRIPE_PRICE_DJ_SUBMISSION=price_...
STRIPE_PRICE_NFT_MINT=price_...
STRIPE_PRICE_NFT_PURCHASE=price_...
STRIPE_PRICE_ARTIST_BOOST=price_...
STRIPE_PRICE_ARTIST_SPOTLIGHT=price_...
STRIPE_PRICE_SHOUTOUT=price_...
STRIPE_PRICE_SUPER_SUPPORTER=price_...
STRIPE_PRICE_SUPPORT_PERFORMER=price_...
STRIPE_PRICE_VENUE_PROMO=price_...
STRIPE_PRICE_VIDEO_CHAT=price_...

# =============================================================================
# EMAIL — Resend (primary transactional provider)
# =============================================================================
# API key from https://resend.com/api-keys (domain verified for themusiciansindex.com)
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=noreply@themusiciansindex.com
EMAIL_FROM_NAME=TMI Platform
EMAIL_FROM=support@themusiciansindex.com

# Optional SendGrid fallback
SENDGRID_API_KEY=SG....

# Optional SMTP fallback
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-username
EMAIL_SMTP_PASS=your-smtp-password
MAIL_FROM=noreply@themusiciansindex.com
MAIL_PROVIDER=resend

# Email API security (optional, for stricter environments)
INTERNAL_EMAIL_API_KEY=your-internal-email-key
EMAIL_API_STRICT_MODE=false
EMAIL_API_REQUIRE_INTERNAL_KEY=false
EMAIL_API_ALLOWED_ORIGINS=https://themusiciansindex.com
ENABLE_EMAIL_AUTOMATION=true

# =============================================================================
# EMAIL QUEUE CRON (Vercel)
# =============================================================================
# Set in Vercel dashboard → Project Settings → Environment Variables
CRON_SECRET=your-cron-secret-here
QUEUE_FLUSH_KEY=tmi-queue-flush-dev

# =============================================================================
# PAYPAL (optional — tips + payments)
# =============================================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENV=live
NEXT_PUBLIC_PAYPAL_HANDLE=your-paypal-username

# =============================================================================
# FILE UPLOADS — Vercel Blob
# =============================================================================
# From Vercel dashboard → Storage → Blob → .env.local button
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# =============================================================================
# VIDEO — Daily.co (WebRTC rooms)
# =============================================================================
DAILY_API_KEY=your-daily-api-key
DAILY_DOMAIN=themusiciansindex
NEXT_PUBLIC_DAILY_DOMAIN=themusiciansindex

# =============================================================================
# AI / LLM
# =============================================================================
# OpenAI (bots, ChatGPT agents, Big Ace, Michael Charlie)
OPENAI_API_KEY=sk-proj-...
# Anthropic Claude (Big Ace voice director, MCP command processing)
ANTHROPIC_API_KEY=sk-ant-...
# Google Gemini (validation, QA)
GOOGLE_GEMINI_KEY=AIza...
# Google Translate
GOOGLE_TRANSLATE_API_KEY=AIza...
# Translation provider selection
TRANSLATION_PROVIDER=google

# =============================================================================
# REDIS (optional — for distributed rate limiting, pub/sub)
# =============================================================================
REDIS_REST_URL=https://your-redis-url.upstash.io
REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# GOOGLE ADSENSE — Ad Slot IDs
# =============================================================================
# Publisher ID hardcoded: ca-pub-4088577529436039
# Create one ad unit per placement at https://www.google.com/adsense
# Copy the numeric "data-ad-slot" value for each unit
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-4088577529436039
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-4088577529436039
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_HOMEPAGE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_LIVE_LOBBY_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_SPONSOR_FALLBACK=
NEXT_PUBLIC_ADSENSE_SLOT_MAGAZINE_LEADERBOARD=
NEXT_PUBLIC_ADSENSE_SLOT_MAGAZINE_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_MAGAZINE_ARTICLE_END=
NEXT_PUBLIC_ADSENSE_SLOT_GAME_SHOW_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_GAME_SHOW_INTERSTITIAL=
NEXT_PUBLIC_ADSENSE_SLOT_SHOW_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_ROOM_LEADERBOARD=
NEXT_PUBLIC_ADSENSE_SLOT_ROOM_BETWEEN_SEGMENTS=

# =============================================================================
# AD NETWORKS (alternative monetization)
# =============================================================================
# Media.net
NEXT_PUBLIC_MEDIANET_CID=your-medianet-cid
# Amazon Publisher Services
NEXT_PUBLIC_AMAZON_PUB_ID=your-amazon-pub-id
# Carbon Ads
NEXT_PUBLIC_CARBON_SERVE=your-carbon-serve-id
NEXT_PUBLIC_CARBON_PLACEMENT=your-carbon-placement-id
# PropellerAds
NEXT_PUBLIC_PROPELLER_ZONE_ID=your-propeller-zone-id

# =============================================================================
# ADMIN
# =============================================================================
ADMIN_API_KEY=tmi-phase1-launch-2026
ADMIN_API_SECRET=your-admin-api-secret
ADMIN_EMAIL=admin@themusiciansindex.com
ADMIN_EMAILS=admin@themusiciansindex.com
INTERNAL_ADMIN_API_KEY=your-internal-admin-key
INTERNAL_TICKET_PRINT_API_KEY=your-ticket-print-key

# Diamond-tier admin access list
DIAMOND_EMAILS=user1@example.com,user2@example.com

# Ticket security
TICKET_SECRET=your-ticket-secret
TICKET_SECRET_SALT=your-ticket-secret-salt

# =============================================================================
# TEAM EMAILS (notification routing)
# =============================================================================
TEAM_EMAIL=team@themusiciansindex.com
OVERSEER_EMAIL=overseer@themusiciansindex.com
BOOKING_ALERT_EMAIL=bookings@themusiciansindex.com
JPAUL_EMAIL=jpaul@themusiciansindex.com
JUSTIN_EMAIL=justin@themusiciansindex.com

# =============================================================================
# BOT SYSTEM
# =============================================================================
# 'memory' (default), 'postgres', 'redis'
BOT_PERSISTENCE_DRIVER=memory
# Required if BOT_PERSISTENCE_DRIVER=postgres
BOT_PERSISTENCE_POSTGRES_ENDPOINT=https://your-neon-endpoint.neon.tech
BOT_PERSISTENCE_POSTGRES_TOKEN=your-neon-token

# =============================================================================
# HARDWARE (TMI custom hardware integration)
# =============================================================================
TMI_HARDWARE_API_KEY=your-hardware-api-key
