# BerntoutGlobal XXL — Environment Variables
NEXT_PUBLIC_MODULE_ID=xxl
NEXT_PUBLIC_MODULE_NAME=BerntoutGlobal XXL
PORT=3002

# ── Runtime ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=xxl:

# ── Program Bridge ────────────────────────────────────────────────────────
# Git commit for HUD version display
VERCEL_GIT_COMMIT_SHA=

# ── Stimulation ───────────────────────────────────────────────────────────
STIMULATION_ENABLED=false
STIMULATION_MODE=QUIET
STIMULATION_INTENSITY=0.4

# ── Sandbox ───────────────────────────────────────────────────────────────
SANDBOX_ENABLED=false
SANDBOX_REDIS_URL=redis://localhost:6381

# ── Monitoring ────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
DEPLOY_TARGET=vercel
