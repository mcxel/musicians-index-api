# Prisma Schema Update - Promo Codes, Hub Registry, Audit Logs
# Add this to your existing schema.prisma

# ==============================================================================
# PROMO CODES - Secure, hashed, expiring, single-use
# ==============================================================================

enum PromoCodeStatus {
  ACTIVE
  EXPIRED
  USED
  REVOKED
}

enum PromoCodeType {
  FREE_TRIAL_DAYS
  PERCENTAGE_DISCOUNT
  FIXED_AMOUNT_CREDIT
  FEATURE_UNLOCK
}

model PromoCode {
  id          String          @id @default(cuid())
  codeHash    String          @unique // Hashed promo code (never store plaintext)
  description String?
  type        PromoCodeType
  value       Float           // 90 = 90 days, 25 = 25%, 5000 = $50
  
  status      PromoCodeStatus @default(ACTIVE)
  maxUses     Int            @default(1)
  usedCount   Int            @default(0)
  
  validFrom   DateTime        @default(now())
  expiresAt   DateTime        // Auto-calculated: now + 90 days
  
  // Relations
  createdBy   User?          @relation("CreatedPromoCodes", fields: [createdById], references: [id])
  createdById String?
  
  usedBy      User?          @relation("UsedPromoCodes", fields: [usedById], references: [id])
  usedById   String?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([expiresAt])
}

# ==============================================================================
# HUB REGISTRY - For multi-hub monitoring
# ==============================================================================

enum HubStatus {
  ONLINE
  OFFLINE
  DEGRADED
}

model HubRegistry {
  id          String    @id @default(cuid())
  name        String    @unique // e.g., "TMI", "StreamWin", "Danika's Law"
  displayName String?
  baseUrl     String    // e.g., "https://tmi.berntout.com"
  apiUrl      String?   // e.g., "https://tmi.berntout.com/api"
  
  // Status
  status      HubStatus @default(OFFLINE)
  lastSeenAt DateTime  @default(now())
  latencyMs   Int?
  
  // Auth
  secretKey   String?   // For authenticated hub-to-hub communication
  
  // Metadata
  description String?
  iconUrl     String?
  color      String?   // Brand color for UI
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

# ==============================================================================
# AUDIT LOGS - For admin actions and compliance
# ==============================================================================

enum AuditAction {
  // User Management
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_CHANGED
  
  // Promo Codes
  PROMO_CREATED
  PROMO_REDEEMED
  PROMO_REVOKED
  PROMO_EXPIRED
  
  // Content
  OFFICIAL_LINK_ADDED
  OFFICIAL_LINK_REMOVED
  ARTICLE_PUBLISHED
  ARTICLE_UNPUBLISHED
  
  // Hub
  HUB_REGISTERED
  HUB_STATUS_CHANGED
  
  // Auth
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  
  // Payments
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  REFUND_ISSUED
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  timestamp DateTime    @default(now())
  
  // Actor (who did it)
  actorId   String?
  actor    User?       @relation(fields: [actorId], references: [id])
  
  // Target (what was affected)
  targetType String?   // e.g., "User", "PromoCode", "HubRegistry"
  targetId   String?
  
  // Details
  details   Json?      // { oldValue: ..., newValue: ..., reason: ... }
  ipAddress  String?
  userAgent  String?
  
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([timestamp])
  @@index([action])
}

# ==============================================================================
# FEATURE FLAGS - For toggling features
# ==============================================================================

model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., " enable_payments", "enable_battles"
  description String?
  enabled     Boolean  @default(false)
  
  // Targeting
  rolloutPercent Int?    // 0-100, for gradual rollout
  allowedRoles Role[]   // Which roles can see this
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([enabled])
}
