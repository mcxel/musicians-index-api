  key         String   @unique // e.g., "julius_gold", "julius_retro"
  name        String
  description String?
  rarity      String   @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  assetUrl    String   // URL to the 3D model/skin

  userUnlocks JuliusUserUnlock[]

  @@map("julius_variants")
}

model JuliusUserUnlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId String
  variant   JuliusVariant @relation(fields: [variantId], references: [id])
  unlockedAt DateTime @default(now())
  source    String   // STORE, REWARD, SEASON_PASS

  @@unique([userId, variantId])
  @@map("julius_user_unlocks")
