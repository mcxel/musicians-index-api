// -- Party & Control Mapping Systems ------------------------------------------

model Party {
  id        String   @id @default(cuid())
  leaderId  String
  createdAt DateTime @default(now())

  leader    User          @relation(fields: [leaderId], references: [id])
  members   PartyMember[]

  @@map("parties")
}

model PartyMember {
  id        String   @id @default(cuid())
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([partyId, userId])
  @@map("party_members")
}

model ControlMappingProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile   Json // { "keyboard": {...}, "gamepad": {...}, "vr": {...} }
  updatedAt DateTime @updatedAt

  @@map("control_mapping_profiles")
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // HOST, PERFORMER, AUDIENCE, MODERATOR
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
  @@map("room_members")
}

// =============================================================================
// PHASE 4: VENUE BOOKING RECOMMENDATION ENGINE
// =============================================================================

enum BookingOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum BookingRequestStatus {
  OPEN
  MATCHED
  CLOSED
  CANCELLED
}

enum EventType {
  LOCAL
  REGIONAL
  INTERNATIONAL
  ONLINE
  LIVESTREAM
  CYPHER
  DANCE_PARTY
  COMPETITION
  OPEN_MIC
  FESTIVAL
}

// -- Venue Profile ------------------------------------------------------------

model VenueProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venueName   String
  venueType   String   @default("CLUB") // CLUB, THEATER, ARENA, BAR, FESTIVAL, ONLINE
  description String?  @db.Text
  website     String?
  logoUrl     String?
  bannerUrl   String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location      VenueLocation?
  availability  VenueAvailability[]
  bookingRequests BookingRequest[]
  bookingHistory  BookingHistory[]
  venueArtistHistory VenueArtistHistory[]
  bookingRules    BookingRules?

  @@map("venue_profiles")
}

model VenueLocation {
  id             String       @id @default(cuid())
  venueProfileId String       @unique
  venueProfile   VenueProfile @relation(fields: [venueProfileId], references: [id], onDelete: Cascade)
  address        String?
  city           String
  state          String?
  country        String       @default("US")
  postalCode     String?
  latitude       Float
  longitude      Float
  timezone       String       @default("UTC")
  currency       String       @default("USD")

  @@map("venue_locations")
}

model VenueAvailability {
  id             String       @id @default(cuid())
  venueProfileId String
  venueProfile   VenueProfile @relation(fields: [venueProfileId], references: [id], onDelete: Cascade)
  date           DateTime
  isAvailable    Boolean      @default(true)
  note           String?

  @@unique([venueProfileId, date])
  @@map("venue_availability")
}

// -- Artist Territory & Availability ------------------------------------------

model ArtistTerritory {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeLatitude            Float?
  homeLongitude           Float?
  homeCity                String?
  homeCountry             String   @default("US")
  travelRadiusKm          Int      @default(100)
  willingToTravelNational Boolean  @default(false)
  willingToTravelIntl     Boolean  @default(false)
  onlineAvailable         Boolean  @default(true)
  budgetMin               Int      @default(0)   // minimum fee in cents
  budgetMax               Int      @default(0)   // 0 = negotiable
  updatedAt               DateTime @updatedAt

  availability ArtistAvailability[]

  @@map("artist_territories")
}

model ArtistAvailability {
  id              String          @id @default(cuid())
  artistTerritoryId String
  artistTerritory ArtistTerritory @relation(fields: [artistTerritoryId], references: [id], onDelete: Cascade)
  date            DateTime
  isAvailable     Boolean         @default(true)
  note            String?

  @@unique([artistTerritoryId, date])
  @@map("artist_availability")
}

// -- Exposure Stats (for underserved boost) -----------------------------------

model ArtistExposureStats {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalViews        Int      @default(0)
  totalBookings     Int      @default(0)
  totalShows        Int      @default(0)
  underservedScore  Float    @default(100.0) // 100 = fully underserved, 0 = overexposed
  lastBookedAt      DateTime?
  lastViewedAt      DateTime?
  updatedAt         DateTime @updatedAt

  @@map("artist_exposure_stats")
}

// -- Booking Request (venue initiates) ----------------------------------------

model BookingRequest {
  id             String               @id @default(cuid())
  venueProfileId String
  venueProfile   VenueProfile         @relation(fields: [venueProfileId], references: [id])
  venueUserId    String
  venueUser      User                 @relation("VenueBookingRequests", fields: [venueUserId], references: [id])
  latitude       Float
  longitude      Float
  radiusKm       Int                  @default(100)
  genres         String[]
  eventDate      DateTime
  budgetMin      Int                  @default(0)
  budgetMax      Int                  @default(0)
  eventType      EventType            @default(LOCAL)
  status         BookingRequestStatus @default(OPEN)
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  matches BookingMatch[]
  offers  BookingOffer[]

  @@index([venueProfileId, status])
  @@index([eventDate])
  @@map("booking_requests")
}

// -- Booking Match (recommendation result row) --------------------------------

model BookingMatch {
  id               String         @id @default(cuid())
  requestId        String
  request          BookingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  artistUserId     String
  artistProfileId  String?
  distanceKm       Float
  score            Float
  distanceScore    Float          @default(0)
  genreScore       Float          @default(0)
  availabilityScore Float         @default(0)
  budgetScore      Float          @default(0)
  exposureBoost    Float          @default(0)
  participationBoost Float        @default(0)
  subscriptionBoost Float         @default(0)
  repeatPenalty    Float          @default(0)
  recentBookingPenalty Float      @default(0)
  tags             String[]       // FRESH_PICK, UNDISCOVERED, RISING, COOLDOWN_BLOCKED, HIGH_PARTICIPATION
  isFirstTimeForVenue Boolean     @default(true)
  isCooldownBlocked   Boolean     @default(false)
  createdAt        DateTime       @default(now())

  @@index([requestId, score])
  @@map("booking_matches")
}

// -- Booking Offer (venue → artist) -------------------------------------------

model BookingOffer {
  id             String             @id @default(cuid())
  requestId      String?
  request        BookingRequest?    @relation(fields: [requestId], references: [id])
  venueUserId    String
  venueUser      User               @relation("VenueBookingOffers", fields: [venueUserId], references: [id])
  artistUserId   String
  artistUser     User               @relation("ArtistBookingOffers", fields: [artistUserId], references: [id])
  eventDate      DateTime
  budgetCents    Int                @default(0)
  currency       String             @default("USD")
  message        String?            @db.Text
  status         BookingOfferStatus @default(PENDING)
  respondedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  history BookingHistory?

  @@index([artistUserId, status])
  @@index([venueUserId, status])
  @@map("booking_offers")
}

// -- Booking History (confirmed bookings) -------------------------------------

model BookingHistory {
  id             String        @id @default(cuid())
  offerId        String        @unique
  offer          BookingOffer  @relation(fields: [offerId], references: [id])
  venueProfileId String
  venueProfile   VenueProfile  @relation(fields: [venueProfileId], references: [id])
  artistUserId   String
  eventDate      DateTime
  budgetCents    Int
  currency       String        @default("USD")
  eventType      EventType     @default(LOCAL)
  confirmedAt    DateTime      @default(now())
  completedAt    DateTime?
  cancelledAt    DateTime?
  note           String?

  @@index([venueProfileId, eventDate])
  @@index([artistUserId, eventDate])
  @@map("booking_history")
}

// -- Venue-Artist Cooldown History --------------------------------------------

model VenueArtistHistory {
  id             String       @id @default(cuid())
  venueProfileId String
  venueProfile   VenueProfile @relation(fields: [venueProfileId], references: [id])
  artistUserId   String
  bookedAt       DateTime
  cooldownUntil  DateTime
  cooldownDays   Int          @default(30)

  @@index([venueProfileId, artistUserId])
  @@index([venueProfileId, cooldownUntil])
  @@map("venue_artist_history")
}

// -- Artist Booking Score (cached composite score) ----------------------------

model ArtistBookingScore {
  id                  String   @id @default(cuid())
  artistUserId        String   @unique
  compositeScore      Float    @default(0)
  distanceScore       Float    @default(0)
  genreScore          Float    @default(0)
  availabilityScore   Float    @default(0)
  budgetScore         Float    @default(0)
  exposureBoost       Float    @default(0)
  participationBoost  Float    @default(0)
  subscriptionBoost   Float    @default(0)
  updatedAt           DateTime @updatedAt

  @@map("artist_booking_scores")
}

// -- Booking Rules (admin-configurable per venue) -----------------------------

model BookingRules {
  id                    String       @id @default(cuid())
  venueProfileId        String       @unique
  venueProfile          VenueProfile @relation(fields: [venueProfileId], references: [id], onDelete: Cascade)
  cooldownDays          Int          @default(30)
  maxCooldownDays       Int          @default(90)
  minPoolSize           Int          @default(5)
  exposureBoostThreshold Int         @default(100) // views below this get boost
  repeatPenaltyPoints   Int          @default(20)
  recentBookingPenalty  Int          @default(10)
  updatedAt             DateTime     @updatedAt

  @@map("booking_rules")
}
