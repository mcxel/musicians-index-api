// PACK 43: REWARDS / GIVEAWAYS / AVATAR ECONOMY — SCHEMA ADDITIONS
// Append to packages/db/prisma/schema.prisma
// Run: pnpm prisma migrate dev --name pack43_rewards

// ── NEW ENUMS ──────────────────────────────────────────────

enum RewardType {
  POINTS
  AVATAR_ITEM
  SPONSOR_ITEM
  DISCOUNT_CODE
  FREE_TICKET
  BACKSTAGE_PASS
  MERCH_ITEM
  DIGITAL_COLLECTIBLE
  BADGE
  TITLE
  RANK_BOOST
  SHOUTOUT
  SKIP_QUEUE
  PRIORITY_ENTRY
  BONUS_VOTE
  MYSTERY_BOX
  WALLET_CREDIT
}

enum RewardTrigger {
  RANDOM_AUDIENCE_DROP
  RANDOM_CONTESTANT_DROP
  FIRST_TO_REACT
  FIRST_CORRECT_ANSWER
  FIRST_TO_JOIN_ROOM
  FIRST_TICKET_BUYER
  FASTEST_RESPONSE
  MODERATOR_MANUAL_GIFT
  HOST_MANUAL_GIFT
  SPONSOR_TRIGGERED
  BOT_TRIGGERED
  STREAK_REWARD
  ATTENDANCE_REWARD
  PARTICIPATION_REWARD
  LOYALTY_REWARD
  SURPRISE_LIVE_DROP
  MILESTONE_REWARD
  LEADERBOARD_REWARD
  CONTEST_WINNER
  AUDIENCE_VOTE_WINNER
  CHALLENGE_COMPLETION
  REFERRAL_REWARD
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  FULFILLED
  FAILED
  FRAUD_REVIEW
  REQUIRES_BIG_ACE
  EXPIRED
}

enum PromptType {
  TRIVIA
  REACTION
  FASTEST_TAP
  FILL_BLANK
  PICK_WINNER
  SHOUTOUT_REQUEST
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

// ── MODELS ────────────────────────────────────────────────

model RewardRule {
  id                         String        @id @default(cuid())
  name                       String
  rewardType                 RewardType
  triggerType                RewardTrigger
  pointsAmount               Int?          // for POINTS reward
  itemId                     String?       // for item rewards
  discountPct                Int?          // for DISCOUNT_CODE
  walletCreditCents          Int?          // Big Ace required if > 0
  eligibleRoles              String[]
  eligibleRoomTypes          String[]
  minimumWatchTimeSeconds    Int           @default(0)
  minimumParticipationActions Int          @default(0)
  requiresTicket             Boolean       @default(false)
  requiresVerifiedAccount    Boolean       @default(false)
  dropOddsPct                Float         @default(100)
  maxClaimsPerUser           Int           @default(1)
  maxClaimsPerEvent          Int           @default(0)  // 0 = unlimited
  maxClaimsPerSession        Int           @default(0)
  cooldownSeconds            Int           @default(0)
  minAccountAgeDays          Int           @default(0)
  maxVelocityPerMinute       Int           @default(10)
  requiresRoomPresence       Boolean       @default(true)
  requiresBigAceApproval     Boolean       @default(false)
  sponsorId                  String?
  campaignId                 String?
  availableFrom              DateTime?
  availableUntil             DateTime?
  isActive                   Boolean       @default(true)
  createdAt                  DateTime      @default(now())

  claims                     RewardClaim[]
  prompts                    AudiencePrompt[]

  @@index([isActive])
  @@index([triggerType])
  @@map("reward_rules")
}

model RewardClaim {
  id                  String             @id @default(cuid())
  userId              String
  ruleId              String
  sessionId           String?            // room or game session
  eventId             String?
  roomId              String?
  rewardType          RewardType
  status              FulfillmentStatus  @default(PENDING)
  pointsGranted       Int?
  itemGrantedId       String?
  discountCode        String?
  walletCreditCents   Int?
  requiresBigAce      Boolean            @default(false)
  requiresFraudReview Boolean            @default(false)
  fraudReviewNote     String?
  fulfilledAt         DateTime?
  expiredAt           DateTime?
  claimedAt           DateTime           @default(now())

  rule                RewardRule         @relation(fields: [ruleId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([claimedAt])
  @@map("reward_claims")
}

model AudiencePrompt {
  id              String      @id @default(cuid())
  sessionId       String
  roomId          String
  ruleId          String
  promptType      PromptType
  question        String?
  correctAnswer   String?
  windowSeconds   Int         @default(15)
  maxWinners      Int         @default(1)
  status          String      @default("pending")
  winners         String[]    // userIds
  firedAt         DateTime?
  closedAt        DateTime?
  createdAt       DateTime    @default(now())

  rule            RewardRule  @relation(fields: [ruleId], references: [id])
  entries         AudiencePromptEntry[]

  @@index([sessionId])
  @@map("audience_prompts")
}

model AudiencePromptEntry {
  id              String         @id @default(cuid())
  promptId        String
  userId          String
  response        String?
  responseTimeMs  Int
  isCorrect       Boolean?
  isWinner        Boolean        @default(false)
  pointsAwarded   Int            @default(0)
  submittedAt     DateTime       @default(now())

  prompt          AudiencePrompt @relation(fields: [promptId], references: [id])

  @@unique([promptId, userId])
  @@map("audience_prompt_entries")
}

model DropTable {
  id                    String           @id @default(cuid())
  name                  String
  sponsorId             String?
  eventId               String?
  guaranteedAfterNDraws Int?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())

  entries               DropTableEntry[]

  @@map("drop_tables")
}

model DropTableEntry {
  id           String    @id @default(cuid())
  tableId      String
  rewardType   RewardType
  itemId       String?
  pointsAmount Int?
  weight       Int       @default(100)
  rarity       ItemRarity @default(COMMON)
  maxTotal     Int?
  droppedCount Int       @default(0)

  table        DropTable @relation(fields: [tableId], references: [id])

  @@map("drop_table_entries")
}

model RewardCooldown {
  id        String   @id @default(cuid())
  userId    String
  ruleId    String
  expiresAt DateTime

  @@unique([userId, ruleId])
  @@map("reward_cooldowns")
}

model RewardFraudFlag {
  id          String   @id @default(cuid())
  userId      String
  claimId     String   @unique
  reason      String
  patternData Json?
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isResolved])
  @@map("reward_fraud_flags")
}

model SponsorPrizeCatalog {
  id          String    @id @default(cuid())
  sponsorId   String
  name        String
  description String?
  imageUrl    String?
  totalQty    Int
  remaining   Int
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([sponsorId])
  @@map("sponsor_prize_catalog")
}

// =============================================================================
// PACK 47: ADVANCED NOTIFICATIONS SYSTEM
// =============================================================================

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING // Job created, not yet processed
  SENT // Sent to the provider
  DELIVERED // Confirmed delivery (if provider supports it)
  FAILED // Failed to send
}

model NotificationTemplate {
  id        String @id @default(cuid())
  type      String @unique // e.g., "USER_SIGNUP_WELCOME", "REWARD_UNLOCKED"
  description String

  // Template content for each channel
  templateEmailSubject String?
  templateEmailBody    String? @db.Text // Can be HTML
  templateSms          String?
  templatePushTitle    String?
  templatePushBody     String?
  templateInAppTitle   String?
  templateInAppBody    String?
  templateInAppHref    String?

  requiredVariables String[] // e.g. ["username", "rewardName"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

// This table will log all outgoing notifications and their status.
model OutgoingNotification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  type      String // e.g., "USER_SIGNUP_WELCOME", links conceptually to NotificationTemplate
  data      Json? // The variables for the template

  // The rendered content at the time of sending
  sentContentSubject String?
  sentContentBody    String? @db.Text

  // For IN_APP notifications, this links to the visible notification
  inAppNotificationId String?           @unique
  inAppNotification   InAppNotification? @relation(fields: [inAppNotificationId], references: [id])

  // Provider-specific info
  provider          String? // e.g., "SendGrid", "Twilio", "FCM"
  providerMessageId String?
  providerError     String? @db.Text

  createdAt   DateTime  @default(now())
  processedAt DateTime?
  deliveredAt DateTime?

  @@index([userId, status, createdAt])
  @@map("outgoing_notifications")
}

// A new model for In-App notifications, linked from the log.
model InAppNotification {
  id      String   @id @default(cuid())
  userId  String
  title   String
  body    String
  href    String?
  isRead  Boolean  @default(false)
  readAt  DateTime?
  expiresAt DateTime?
  metadata Json?
  createdAt DateTime @default(now())

  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  outgoingNotification OutgoingNotification?

  @@index([userId, isRead, createdAt])
  @@map("in_app_notifications")
}

// =============================================================================
// TMI LIVE WORLD SYSTEM (PACK 49+)
// =============================================================================

// -- Live Rooms, Auditoriums, and Sections ------------------------------------

model Room {
  id          String   @id @default(cuid())
  name        String
  type        String // LOBBY, THEATER, ARENA, BAR_LOUNGE, CLUB, etc.
  status      String   @default("CLOSED") // CLOSED, PRESHOW, LIVE, POSTSHOW, ARCHIVED
  ownerId     String?
  maxCapacity Int      @default(10000)

  owner    User?         @relation(fields: [ownerId], references: [id])
  sections Section[]
  sessions RoomSession[]
  members  RoomMember[]

  @@map("rooms")
}

model Section {
  id        String @id @default(cuid())
  roomId    String
  room      Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  status    String @default("OPEN") // OPEN, FULL, CLOSED
  memberIds String[]

  @@map("sections")
}

model RoomSession {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  status    String // PENDING, ACTIVE, PAUSED, ENDED
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@map("room_sessions")
}

// -- Lobby System: Personal, Party, and Upgrades ------------------------------

model Lobby {
