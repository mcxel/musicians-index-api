// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql" // Using PostgreSQL, a robust choice for production
}

generator client {
  provider = "prisma-client-js"
  // place client in a more accessible location for the monorepo
  output   = "../../../node_modules/.prisma/client"
}

// ==============================================================================
// AUTHENTICATION & USER MODELS
// Based on NextAuth.js schema for easy integration
// ==============================================================================

// User roles for implementing Role-Based Access Control (RBAC)
enum Role {
  USER // Standard user, can consume content
  ARTIST // An artist with a public profile
  STAFF // Can manage content, but not system settings
  ADMIN // Full administrative access
  JUDGE // A judge for competitions
  SPONSOR // A sponsor with access to specific dashboards
}

enum OnboardingState {
  NO_ROLE_SELECTED
  INCOMPLETE
  COMPLETE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  onboardingState      OnboardingState @default(NO_ROLE_SELECTED)
  onboardingCompletedAt DateTime?
  canSubmitOfficialPlatformLinks Boolean @default(false)
  accounts      Account[]
  sessions      Session[]

  // A user can be associated with an artist profile
  artistProfile Artist?

  // Stripe-related fields
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  stripePriceId          String?   @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")

  // Ledger
  ledgerEntries LedgerEntry[]

  // Relations added for schema additions
  musicLinksAdded   MusicLink[]    @relation("MusicLinkAddedBy")
  createdPromoCodes PromoCode[]    @relation("CreatedPromoCodes")
  usedPromoCodes    PromoCode[]    @relation("UsedPromoCodes")
  subscriptions     Subscription[] @relation("UserSubscriptions")
  auditLogs         AuditLog[]     @relation("UserAuditLogs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==============================================================================
// APPLICATION-SPECIFIC MODELS
// ==============================================================================

model Artist {
  id   String  @id @default(cuid())
  name String
  bio  String? @db.Text

  // Link back to the user account
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // An artist can have multiple official music links
  musicLinks MusicLink[]
}

model MusicLink {
  id       String @id @default(cuid())
  platform String // e.g., "Spotify", "Apple Music", "SoundCloud"
  url      String

  // The artist this link belongs to
  artistId String
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // Who added this link? For auditing purposes.
  // This helps enforce the rule about who can add links.
  addedById String
  addedBy   User   @relation("MusicLinkAddedBy", fields: [addedById], references: [id])
}

// ==============================================================================
// PAYMENTS & SUBSCRIPTIONS (STRIPE)
// ==============================================================================

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
}

model Product {
  id          String  @id @map("id") // Stripe Product ID
  active      Boolean
  name        String
  description String?
  image       String?
  metadata    Json?
  prices      Price[]
}

model Price {
  id            String         @id @map("id") // Stripe Price ID
  productId     String         @map("product_id")
  product       Product        @relation(fields: [productId], references: [id])
  active        Boolean
  description   String?
  unitAmount    Int?           @map("unit_amount")
  currency      String
  type          String // "one_time" or "recurring"
  interval      String? // "day", "week", "month", "year"
  metadata      Json?
  subscriptions Subscription[] @relation("PriceSubscriptions")
}

model Subscription {
  id                 String             @id @map("id") // Stripe Subscription ID
  userId             String             @unique
  user               User               @relation("UserSubscriptions", fields: [userId], references: [id])
  status             SubscriptionStatus
  metadata           Json?
  priceId            String             @map("price_id")
  price              Price              @relation("PriceSubscriptions", fields: [priceId], references: [id])
  cancelAtPeriodEnd  Boolean            @map("cancel_at_period_end")
  created            DateTime
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
}

// ==============================================================================
// LEDGER / VIRTUAL CURRENCY
// ==============================================================================
enum LedgerEntryType {
  CREDIT // Adding currency to a user's balance
  DEBIT // Spending currency from a user's balance
}

model LedgerEntry {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        LedgerEntryType
  amount      Int // The amount of virtual currency
  description String
  relatedId   String? // ID of a related object (e.g., Tip, Vote, Purchase)
  createdAt   DateTime        @default(now())

  @@index([userId])
}

// ==============================================================================
// PROMOTIONS & MARKETING
// ==============================================================================

enum PromoCodeStatus {
  ACTIVE
  EXPIRED
  USED
  REVOKED
}

enum PromoCodeType {
  FREE_TRIAL_DAYS
  PERCENTAGE_DISCOUNT
  FIXED_AMOUNT_CREDIT
  FEATURE_UNLOCK
}

model PromoCode {
  id          String          @id @default(cuid())
  codeHash    String          @unique // The hashed promo code, for security
  description String
  type        PromoCodeType
  value       Float // e.g., 90 (days), 25 (percent), 5000 (cents)
  status      PromoCodeStatus @default(ACTIVE)

  maxUses   Int @default(1)
  usedCount Int @default(0)

  validFrom DateTime
  expiresAt DateTime

  // Who created this code?
  createdBy   User   @relation("CreatedPromoCodes", fields: [createdById], references: [id])
  createdById String

  // Who used this code?
  usedBy   User?   @relation("UsedPromoCodes", fields: [usedById], references: [id])
  usedById String?

  // Audit trail for this specific code
  auditHistory AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==============================================================================
// AUDITING & LOGGING
// ==============================================================================

enum AuditLogAction {
  // Promo Actions
  PROMO_CODE_CREATED
  PROMO_CODE_REDEEMED
  PROMO_CODE_REVOKED
  PROMO_CODE_EXPIRED

  // Admin Actions
  USER_ROLE_CHANGED
  OFFICIAL_LINK_ADDED
  OFFICIAL_LINK_REMOVED
}

model AuditLog {
  id        String         @id @default(cuid())
  action    AuditLogAction
  timestamp DateTime       @default(now())

  // The user who performed the action
  actor   User   @relation("UserAuditLogs", fields: [actorId], references: [id])
  actorId String

  // Optional: The entity that was acted upon
  targetId String?
  details  Json? // Store extra context as JSON

  // Can be linked to a promo code
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoCodeId String?

  @@index([actorId])
  @@index([targetId])
}

// ==============================================================================
// HUB & MODULE REGISTRY
// ==============================================================================

enum HubStatus {
  ONLINE
  OFFLINE
  DEGRADED
}

model Hub {
  id          String    @id @default(cuid())
  name        String    @unique
  baseUrl     String
  description String?
  status      HubStatus @default(OFFLINE)
  iconUrl     String?

  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Feature flags for gradual rollouts and safe toggles
model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?
  enabled     Boolean @default(false)
  notes       String?

  // Stored as JSON to avoid enum-array portability issues across providers
  targeting Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// ======================================================================
// TICKETING CORE (Phase 1)
// Minimal models to support Event, TicketType, Ticket, CheckIn, Order
// Refund-ready fields are included but payment processing is out of scope
// ======================================================================

enum EventStatus {
  DRAFT
  PUBLISHED
  ON_SALE
  DOORS_OPEN
  STARTED
  ENDED
  CANCELED
  RESCHEDULED
}

enum TicketStatus {
  ACTIVE
  CANCELED
  REFUND_PENDING
  REFUNDED
  USED
}

model Event {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  title        String
  description  String?     @db.Text
  startsAt     DateTime
  endsAt       DateTime?
  timezone     String?
  venueName    String?
  venueCity    String?
  venueState   String?
  venueCountry String?

  // ownership / organizer hooks
  artistUserId String?
  venueUserId  String?

  status       EventStatus @default(PUBLISHED)
  cancelReason String?
  canceledAt   DateTime?

  // optional lightweight refund policy JSON for MVP
  refundPolicy Json?

  ticketTypes  TicketType[]
  tickets      Ticket[]
}

model TicketType {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name       String   // e.g., "GA", "VIP"
  priceCents Int      @default(0)
  currency   String   @default("USD")
  quantity   Int      @default(0)

  tickets    Ticket[]
}

model Order {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  buyerUserId        String?
  provider           String?  // e.g. STRIPE
  providerPaymentId  String?  // e.g. stripe payment intent / charge id
  currency           String?
  amountCents        Int?
  status             String?  // PAID | REFUND_PENDING | REFUNDED

  tickets            Ticket[]
  refunds            Refund[]
}

model Ticket {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  eventId      String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  ticketTypeId String
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id])

  orderId      String?
  order        Order?       @relation(fields: [orderId], references: [id])

  ownerUserId  String?
  status       TicketStatus @default(ACTIVE)

  // store only a hash of the ticket token
  tokenHash    String       @unique
  issuedAt     DateTime     @default(now())

  checkedInAt  DateTime?
  checkIns     CheckIn[]
  refunds      Refund[]
}

model CheckIn {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  ticketId         String
  ticket           Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  checkedInByUserId String?
  note             String?
}

// ======================================================================
// REFUNDS & POLICIES
// Keep these models ready for Prisma migrations and later wiring to Stripe
// ======================================================================

enum RefundReason {
  CUSTOMER_REQUEST
  EVENT_CANCELLED
  EVENT_POSTPONED
  FRAUD
  DUPLICATE
  OTHER
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum RefundProcessor {
  STRIPE
  ESCROW
}

model RefundPolicy {
  id          String   @id @default(cuid())
  name        String
  description String?
  // JSON rules: refundableUntilHours, refundableFees, partialAllowed, tierRules, etc
  rules       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Refund {
  id                 String         @id @default(cuid())
  orderId            String
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketId           String?
  ticket             Ticket?        @relation(fields: [ticketId], references: [id])
  amountCents        Int
  currency           String         @default("USD")
  reason             RefundReason
  status             RefundStatus   @default(REQUESTED)
  processor          RefundProcessor?
  processorRefundId  String?
  idempotencyKey     String?         @unique
  createdAt          DateTime        @default(now())
  processedAt        DateTime?
  metadata           Json?
}

// Contest System (appended by install-contest-system.ps1)
// ═══════════════════════════════════════════════════════════════════════════
// PRISMA SCHEMA ADDITIONS — TMI Grand Platform Contest System
// BerntoutGlobal XXL
//
// Repo path: prisma/schema.prisma
// Action: ADD these models to your existing schema.prisma file
//         Do NOT replace existing models — append only
//
// After adding, run:
//   npx prisma generate
//   npx prisma migrate dev --name add_contest_system
// ═══════════════════════════════════════════════════════════════════════════

// ─── Contest Season ──────────────────────────────────────────────────────────

model ContestSeason {
  id          String   @id @default(cuid())
  name        String   // "Grand Platform Contest — Season 1"
  status      String   @default("upcoming") // upcoming | active | completed | archived

  // Contest open gate (must enforce Aug 8 policy)
  startDate             DateTime
  registrationOpen      DateTime
  registrationClose     DateTime

  // Key dates
  registrationStartDate      DateTime
  registrationEndDate        DateTime
  sponsorCollectionEndDate   DateTime
  regionalsStartDate         DateTime
  regionalsEndDate           DateTime
  semiFinalsStartDate        DateTime
  semiFinalsEndDate          DateTime
  finalsDate                 DateTime

  prizePool    Float?
  description  String?

  // Relations
  entries  ContestEntry[]
  rounds   ContestRound[]
  prizes   ContestPrize[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contest_seasons")
}

// ─── Contest Entry ───────────────────────────────────────────────────────────

model ContestEntry {
  id          String   @id @default(cuid())

  // Artist reference — update this foreign key to match your User/Artist model
  artistId    String
  // artist   User   @relation(fields: [artistId], references: [id])

  seasonId    String
  season      ContestSeason @relation(fields: [seasonId], references: [id])

  category    String   // singers | rappers | comedians | dancers | djs | bands | beatmakers | magicians | influencers | freestyle | other
  stageName   String?
  performanceDescription  String?

  status      String   @default("pending")
  // pending | qualified | regional | semi_finals | finals | winner | eliminated | disqualified

  // Cached sponsor counts (updated via trigger/hook)
  localSponsorCount  Int @default(0)
  majorSponsorCount  Int @default(0)

  // Relations
  sponsorContributions  SponsorContribution[]
  votes                 ContestVote[]
  round                 ContestRound?  @relation(fields: [roundId], references: [id])
  roundId               String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([artistId, seasonId])  // one entry per artist per season
  @@map("contest_entries")
}

// ─── Sponsor Contribution ────────────────────────────────────────────────────

model SponsorContribution {
  id       String @id @default(cuid())

  entryId  String
  entry    ContestEntry @relation(fields: [entryId], references: [id])

  // Sponsor reference — update to match your Sponsor/User model
  sponsorId  String
  // sponsor  Sponsor @relation(fields: [sponsorId], references: [id])

  packageId    String  // 'local-bronze' | 'local-silver' | 'local-gold' | 'major-bronze' | 'major-silver' | 'major-gold' | 'title'
  packageLabel String
  packageType  String  // 'local' | 'major'
  amount       Float

  message   String?
  adminNote String?

  status  String @default("invited")
  // invited | pending_payment | payment_received | verified | rejected

  // Payment tracking
  paymentReference  String?
  paymentVerifiedAt DateTime?
  verifiedById      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entryId, sponsorId])  // one contribution per sponsor per entry
  @@map("sponsor_contributions")
}

// ─── Sponsor Package (static/config, but storing for flexibility) ────────────

model SponsorPackage {
  id          String  @id
  label       String
  packageType String  // 'local' | 'major'
  tier        String  // 'bronze' | 'silver' | 'gold' | 'title'
  price       Float
  description String?
  benefits    Json?   // array of benefit strings
  isActive    Boolean @default(true)

  @@map("sponsor_packages")
}

// ─── Contest Round ───────────────────────────────────────────────────────────

model ContestRound {
  id        String @id @default(cuid())

  seasonId  String
  season    ContestSeason @relation(fields: [seasonId], references: [id])

  name       String  // "Qualification" | "Regional Round" | "Semi-Finals" | "Grand Finals"
  roundType  String  // "qualification" | "regional" | "semi_finals" | "finals"
  order      Int

  startDate  DateTime
  endDate    DateTime
  status     String @default("upcoming") // upcoming | active | voting | completed

  category   String?  // optional per-category round

  entries    ContestEntry[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contest_rounds")
}

// ─── Contest Vote ────────────────────────────────────────────────────────────

model ContestVote {
  id       String @id @default(cuid())

  entryId  String
  entry    ContestEntry @relation(fields: [entryId], references: [id])

  roundId  String
  // round  ContestRound @relation(...)

  // Voter reference — update to match your User model
  voterId  String

  // Sponsor vote weight (major sponsors may get weighted vote)
  weight   Float @default(1.0)

  createdAt  DateTime @default(now())

  @@unique([entryId, voterId, roundId])  // one vote per user per entry per round
  @@map("contest_votes")
}

// ─── Contest Prize ───────────────────────────────────────────────────────────

model ContestPrize {
  id        String @id @default(cuid())

  seasonId  String
  season    ContestSeason @relation(fields: [seasonId], references: [id])

  name        String  // "Grand Prize" | "Runner Up" | "Sponsor Deal" etc
  description String?
  prizeType   String  // 'cash' | 'deal' | 'equipment' | 'tour' | 'recording' | 'brand_partnership'

  cashValue   Float?
  otherValue  String?   // description if non-cash

  placement   Int   // 1 = first place, 2 = second, etc.
  category    String?   // null = all categories

  // Fulfillment
  fulfillments  PrizeFulfillment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("contest_prizes")
}

// ─── Prize Fulfillment ───────────────────────────────────────────────────────

model PrizeFulfillment {
  id       String @id @default(cuid())

  prizeId  String
  prize    ContestPrize @relation(fields: [prizeId], references: [id])

  // Winner reference
  artistId  String
  entryId   String

  status  String @default("pending")
  // pending | processing | delivered | verified | disputed

  notes           String?
  deliveredAt     DateTime?
  verifiedAt      DateTime?
  adminId         String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("prize_fulfillments")
}

// ─── Ray Journey Script Library ──────────────────────────────────────────────

model RayJourneyScript {
  id      String @id @default(cuid())

  type    String
  // contestant_intro | sponsor_shoutout | prize_reveal | round_transition | winner_announce | crowd_hype | co_host_handoff

  text    String
  emotion String  @default("neutral")
  // neutral | excited | announcing | revealing | crowd | sponsor

  variables  Json?   // template variables like {{contestantName}}, {{sponsorName}}
  order      Int     @default(0)
  isActive   Boolean @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ray_journey_scripts")
}

// ─── Host Cue Log ────────────────────────────────────────────────────────────

model HostCue {
  id        String @id @default(cuid())

  scriptId  String
  // script  RayJourneyScript @relation(...)

  triggeredBy  String  // admin/host userId
  context      Json?   // resolved variables used

  createdAt  DateTime @default(now())

  @@map("host_cues")
}
