  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier     String  @default("FREE") // FREE, BRONZE, GOLD, PLATINUM, DIAMOND
  theme    String  @default("default_theater")
  level    Int     @default(1)
  
  displayItems LobbyDisplayItem[]
  
  @@map("lobbies")
}

model LobbyTheme {
  id          String  @id @default(cuid())
  key         String  @unique // e.g., "vibe_hiphop", "neon_retro"
  name        String
  description String?
  assetUrl    String? // URL to the theme's asset bundle
  isPremium   Boolean @default(false)

  @@map("lobby_themes")
