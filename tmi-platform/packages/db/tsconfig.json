{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src/**/*","prisma/**/*"],
  "exclude": ["node_modules"]
}
