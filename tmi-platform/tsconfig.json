{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@tmi/*": ["packages/*/src"]
    }
  },
  "include": [
    "apps/web/**/*",
    "packages/hud-core/src/**/*",
    "packages/hud-runtime/src/**/*",
    "packages/hud-theme/src/**/*",
    "packages/hud-tmi/src/**/*",
    "packages/promo-bridge/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/.next"
  ]
}
